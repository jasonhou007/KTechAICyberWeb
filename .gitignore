# Dependencies
node_modules/

# Build output
dist/
build/

# Test coverage (generated by vitest — must never be committed)
/coverage/
coverage/

# Editor/agent temp & backup files
*.bak
*.tmp
*.tmp.*
*.debug.test.*

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Playwright
/playwright-report/
/playwright/.cache/
/test-results/
/playwright-traces/
/screenshots/
/test-results.json
/junit-results.xml

# Perf/lighthouse evidence artifacts (generated by scripts/*-evidence.mjs +
# the FPS E2E specs). These are runtime artifacts saved for the ticket archive
# + PR body; they are NOT source and must not be committed. The convention
# mirrors /coverage/ and /playwright-report/: keep on disk, ignore in git.
/projects/*/projects/*/evidence/
