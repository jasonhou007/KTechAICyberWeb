<svg width="800" height="450" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0a0a0f;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#1a1a2e;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
      <stop offset="0%" style="stop-color:#00f0ff;stop-opacity:0.2" />
      <stop offset="50%" style="stop-color:#00f0ff;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#00f0ff;stop-opacity:0.2" />
    </linearGradient>
  </defs>
  <rect width="800" height="450" fill="url(#bgGrad2)" />
  <g opacity="0.1">
    <pattern id="grid2" width="40" height="40" patternUnits="userSpaceOnUse">
      <path d="M 40 0 L 0 0 0 40" fill="none" stroke="#00f0ff" stroke-width="1"/>
    </pattern>
    <rect width="800" height="450" fill="url(#grid2)" />
  </g>
  <g transform="translate(100, 100)">
    <path d="M 0 150 L 100 50 L 200 120 L 300 30 L 400 100 L 500 40 L 600 80" stroke="url(#lineGrad)" stroke-width="3" fill="none" opacity="0.9" />
    <circle cx="100" cy="50" r="6" fill="#00f0ff" opacity="0.9" />
    <circle cx="200" cy="120" r="6" fill="#00f0ff" opacity="0.8" />
    <circle cx="300" cy="30" r="6" fill="#00f0ff" opacity="0.9" />
    <circle cx="400" cy="100" r="6" fill="#00f0ff" opacity="0.8" />
    <circle cx="500" cy="40" r="6" fill="#00f0ff" opacity="0.9" />
    <circle cx="600" cy="80" r="6" fill="#00f0ff" opacity="0.8" />
    <path d="M 0 150 L 600 80" stroke="#00f0ff" stroke-width="1" opacity="0.2" stroke-dasharray="5,5" />
  </g>
  <text x="400" y="380" font-family="Arial, sans-serif" font-size="24" fill="#00f0ff" text-anchor="middle" opacity="0.9">Fintech Innovation Summit</text>
</svg>
